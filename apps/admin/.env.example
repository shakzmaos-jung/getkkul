# 관제 어드민 배포 전용 env (EXECUTION-PLAN §7). 실제 값은 gitignore된 .env.local.
# ⚠️ service_role 키는 서버 전용 · 어드민 배포에만 · NEXT_PUBLIC_ 에 절대 두지 말 것.

# Supabase (조회·인증)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 관제 read-layer (서버 전용). 없으면 NEXT_PUBLIC_SUPABASE_URL 을 URL로 사용.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
