{
  "name": "getkkul-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start -w apps/web",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "pipeline": "npm run pipeline -w apps/web",
    "pipeline-check": "npm run pipeline-check -w apps/web",
    "deliver": "npm run deliver -w apps/web",
    "gen:oss-licenses": "npm run gen:oss-licenses -w apps/web",
    "gen:security": "node scripts/gen-security-snapshot.mjs"
  }
}
