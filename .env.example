# getkkul 환경변수 템플릿 — 실제 값은 .env.local(git 미추적)에 둔다.
# 시크릿/서비스 롤 키는 서버측에서만 사용한다 (SSR H4).

# --- Supabase (인증 / DB / RLS) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 전용 — 클라이언트로 노출 금지
SUPABASE_SERVICE_ROLE_KEY=

# --- 요약 LLM (Claude) — ADR-0001 ---
ANTHROPIC_API_KEY=

# --- STT 폴백 (OpenAI Whisper) — ADR-0001 ---
OPENAI_API_KEY=

# --- 채널 식별 (YouTube Data API v3) — ADR-0003. 서버 전용 ---
YOUTUBE_API_KEY=
# 데이터센터 IP 봇차단 우회용 yt-dlp 쿠키 파일 경로(선택). CI 에선 YOUTUBE_COOKIES 시크릿→파일.
YTDLP_COOKIES_FILE=

# --- 이메일 발송 ---
# 우선순위: GMAIL_* 있으면 Gmail SMTP(무료·임의 수신), 없으면 Resend
# Gmail: 2단계 인증 후 앱 비밀번호 발급. 발신은 인증 계정으로 나감.
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Resend (SSR AC-F1.3) — 도메인 인증 전엔 본인 이메일로만 발송
RESEND_API_KEY=
# 발신 주소(검증 도메인) 또는 테스트: "getkkul <onboarding@resend.dev>"
DELIVERY_FROM_EMAIL=
# 이메일 내 웹 링크 베이스
APP_BASE_URL=https://getkkul.vercel.app

# --- 스케줄러(Vercel Cron) 보호용 시크릿 ---
CRON_SECRET=
