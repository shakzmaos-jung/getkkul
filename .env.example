# getkkul 환경변수 템플릿 — 실제 값은 .env.local(git 미추적)에 둔다.
# 시크릿/서비스 롤 키는 서버측에서만 사용한다 (SSR H4).

# --- Supabase (인증 / DB / RLS) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 전용 — 클라이언트로 노출 금지
SUPABASE_SERVICE_ROLE_KEY=

# --- 요약 LLM (Claude) — ADR-0001 ---
ANTHROPIC_API_KEY=

# --- STT 폴백 (OpenAI Whisper) — ADR-0001 ---
OPENAI_API_KEY=

# --- 이메일 발송 (Resend) — SSR AC-F1.3 ---
RESEND_API_KEY=

# --- 스케줄러(Vercel Cron) 보호용 시크릿 ---
CRON_SECRET=
